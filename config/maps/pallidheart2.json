      "x": 280,
      "y": 1680,
      "w": 560,
      "h": 560,
      "revealed": false,
      "description": "A dark corridor. The floorboards creak ominously. Something skittered in the shadows."
    },
    {
      "id": "upper-hallway-center",
      "name": "Center Hallway",
      "x": 840,
      "y": 1680,
      "w": 980,
      "h": 560,
      "revealed": false,
      "description": "The main upper hallway. Faded portraits line the walls — their eyes seem to follow you."
    },
    {
      "id": "upper-hallway-east",
      "name": "East Hallway",
      "x": 1820,
      "y": 1680,
      "w": 1260,
      "h": 560,
      "revealed": false,
      "description": "The hallway stretches into shadow. A cold draft seeps from under one of the doors."
    },
    {
      "id": "storage-closet",
      "name": "Storage Closet",
      "x": 280,
      "y": 840,
      "w": 700,
      "h": 140,
      "revealed": false,
      "description": "A cramped closet. Dusty shelves hold old linens and a locked trunk.",
      "checks": [
        {
          "skill": "investigation",
          "dc": 12,
          "successText": "Inside the trunk: bloody rags and a silver knife wrapped in cloth. The blood is fresh.",
          "failText": "Just old linens and dust.",
          "triggerOnce": true
        }
      ]
    },
    {
      "id": "landing",
      "name": "Upper Landing",
      "x": 980,
      "y": 840,
      "w": 2100,
      "h": 840,
      "revealed": false,
      "description": "A wide landing at the top of the stairs. Candlelight flickers. The air smells of old wood and something metallic."
    },
    {
      "id": "room-1",
      "name": "Guest Room — West",
      "x": 280,
      "y": 140,
      "w": 700,
      "h": 700,
      "revealed": false,
      "description": "A modest guest room. The bed is unmade, sheets tangled. Scratch marks run along the inside of the door.",
      "checks": [
        {
          "skill": "investigation",
          "dc": 13,
          "successText": "Under the mattress: a torn journal page. 'They come at night. The innkeeper watches. Do not drink the wine.'",
          "failText": "The room appears to have been used recently but nothing unusual stands out.",
          "triggerOnce": true
        }
      ]
    },
    {
      "id": "room-2",
      "name": "Guest Room — Center-West",
      "x": 980,
      "y": 140,
      "w": 700,
      "h": 700,
      "revealed": false,
      "description": "This room reeks of decay. The window is nailed shut from the inside. Dark stains on the floorboards.",
      "checks": [
        {
          "skill": "perception",
          "dc": 14,
          "successText": "You hear faint scratching from inside the walls. Something is alive in there.",
          "failText": "The room is unpleasant but quiet.",
          "triggerOnce": true
        },
        {
          "skill": "investigation",
          "dc": 15,
          "successText": "The dark stains are blood — lots of it, poorly cleaned. A loose floorboard conceals a hole down to the ground floor.",
          "failText": "Old stains. Could be wine, could be worse.",
          "triggerOnce": true
        }
      ]
    },
    {
      "id": "room-3",
      "name": "Guest Room — Center-East",
      "x": 1680,
      "y": 140,
      "w": 700,
      "h": 700,
      "revealed": false,
      "description": "A cold room. The fireplace is dark and the bed has not been slept in for days. A half-packed travel bag sits by the door.",
      "checks": [
        {
          "skill": "investigation",
          "dc": 11,
          "successText": "The travel bag belongs to a merchant named Henryk. His journal mentions hearing screams from the cellar two nights ago.",
          "failText": "Someone left in a hurry.",
          "triggerOnce": true
        }
      ]
    },
    {
      "id": "room-4",
      "name": "Marta's Room",
      "x": 2380,
      "y": 140,
      "w": 700,
      "h": 700,
      "revealed": false,
      "description": "The innkeeper's private quarters. Surprisingly well-appointed for a roadside inn. Heavy curtains block the window.",
      "checks": [
        {
          "skill": "investigation",
          "dc": 16,
          "successText": "Behind a loose stone in the fireplace: a pouch of silver coins stamped with an unfamiliar crest, and a letter sealed with black wax. The letter reads: 'Keep them fed. He grows impatient.'",
          "failText": "A tidy room. Marta keeps her things in order.",
          "triggerOnce": true
        },
        {
          "skill": "perception",
          "dc": 13,
          "successText": "A faint sweet smell — like incense, but wrong. It reminds you of embalming herbs.",
          "failText": "The room smells clean.",
          "triggerOnce": true
        }
      ]
    }
  ],

# Dark Pilgrimage Co-DM Environment Variables
# Copy this to .env and fill in your values

# Gemini API Key (from aistudio.google.com/apikeys)
GEMINI_API_KEY=your-gemini-key-here

# Hubitat Maker API Token
HUBITAT_TOKEN=your-hubitat-token-here

# Session config file to load on startup (optional)
# SESSION_CONFIG=config/session-0.json

# Whisper settings
WHISPER_MODEL=base.en
WHISPER_THREADS=4
MIN_AUDIO_SECONDS=4.0
